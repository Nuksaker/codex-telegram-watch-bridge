{
  "name": "codex-telegram-watch-bridge",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Windows-first private Telegram bridge for Codex completion notifications and safe session resume.",
  "engines": {
    "node": ">=22.5.0"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "setup": "node dist/cli/setup.js",
    "doctor": "node dist/cli/doctor.js",
    "hook:install": "node dist/cli/hook.js install",
    "hook:status": "node dist/cli/hook.js status",
    "hook:uninstall": "node dist/cli/hook.js uninstall",
    "startup:install": "node dist/cli/startup.js install",
    "startup:status": "node dist/cli/startup.js status",
    "startup:uninstall": "node dist/cli/startup.js uninstall"
  },
  "dependencies": {
    "dotenv": "^17.2.3",
    "fastify": "^5.6.2",
    "grammy": "^1.38.3",
    "pino": "^10.1.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "eslint": "^9.39.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.48.0",
    "vitest": "^4.0.14"
  }
}
