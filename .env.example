# Copy only for development. `npm run setup` stores the real file under
# %LOCALAPPDATA%\CodexTelegramBridge by default.
TELEGRAM_BOT_TOKEN=replace_locally
TELEGRAM_ALLOWED_USER_ID=123456789
TELEGRAM_ALLOWED_CHAT_ID=123456789
BRIDGE_SECRET=generate_with_setup
BRIDGE_HOST=127.0.0.1
BRIDGE_PORT=47831
BRIDGE_RUNTIME_DIR=C:\\Users\\you\\AppData\\Local\\CodexTelegramBridge
CODEX_BIN=codex
MAX_PROMPT_CHARS=6000
MAX_EXCERPT_CHARS=700
GLOBAL_CONCURRENCY=1
LOG_LEVEL=info
